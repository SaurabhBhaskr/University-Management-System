{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build University Management System",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "$sources = Get-ChildItem -Recurse src -Filter *.java | ForEach-Object { $_.FullName }; javac -cp 'lib/*' -d 'build/classes' $sources; Copy-Item -Recurse -Force 'src/icons' 'build/classes/icons'"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$javac"
    }
  ]
}
